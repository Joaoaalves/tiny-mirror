# =============================================================================
# tiny-mirror — Variaveis de Ambiente
# =============================================================================
# Copie este arquivo para `.env` e preencha os valores reais.
# O `.env` real NUNCA deve ser commitado (ver .gitignore).

# -----------------------------------------------------------------------------
# Banco de dados
# -----------------------------------------------------------------------------
# URL de conexao assincrona com PostgreSQL.
# Formato obrigatorio: postgresql+asyncpg://usuario:senha@host:porta/nome_do_banco
# O prefixo `postgresql+asyncpg://` e obrigatorio para SQLAlchemy usar o driver async.
DATABASE_URL=postgresql+asyncpg://tiny_mirror:<dev_db_password>@localhost:5432/tiny_mirror_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# URL de conexao com Redis. Formato: redis://host:porta/numero_do_banco
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
# URL de conexao com RabbitMQ. Formato: amqp://usuario:senha@host:porta/vhost
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# -----------------------------------------------------------------------------
# Tiny ERP
# -----------------------------------------------------------------------------
# Credenciais da aplicacao registrada no painel de integracoes do Tiny:
# https://erp.tiny.com.br/integracoes
TINY_CLIENT_ID=seu_client_id_aqui
TINY_CLIENT_SECRET=seu_client_secret_aqui
#
# Tokens iniciais ja obtidos manualmente. Usados apenas para bootstrap:
# na primeira inicializacao a aplicacao copia esses valores para a tabela
# `oauth_tokens` e, a partir dai, faz rotacao via refresh_token contra
# https://accounts.tiny.com.br/realms/tiny/protocol/openid-connect/token
# (grant_type=refresh_token). Apos a primeira rotacao a fonte de verdade
# passa a ser o banco — os valores aqui ficam obsoletos e podem ser removidos.
TINY_ACCESS_TOKEN=seu_access_token_aqui
TINY_REFRESH_TOKEN=seu_refresh_token_aqui
#
# CNPJ esperado nos payloads de webhook do Tiny. Os endpoints /webhooks/*
# rejeitam (com WARNING + 200) qualquer payload que tenha cnpj diferente.
# OBRIGATORIO em production: a app recusa a subir (fail-fast no lifespan)
# se APP_ENV=production e este campo estiver vazio.
TINY_EXPECTED_CNPJ=

# -----------------------------------------------------------------------------
# Mercado Livre (estoque Full ML)
# -----------------------------------------------------------------------------
# Pull do estoque Full direto da API do ML (substitui o deposito "Full Mercado
# Livre" do Tiny, que e marcado ignore=true e mostra saldos negativos).
# Se ML_CLIENT_ID estiver vazio o sync de ML stock fica desativado.
#
# user_id do vendedor no ML (offshop = 227584372).
ML_USER_ID=
# Credenciais da app registrada no painel de devs do Mercado Livre.
ML_CLIENT_ID=
ML_CLIENT_SECRET=
# Tokens iniciais (mesmo padrao bootstrap do Tiny: na primeira inicializacao
# os valores aqui sao copiados para a tabela `ml_oauth_tokens` e a partir
# dai a fonte de verdade passa a ser o banco). access_token tem TTL de 6h;
# refresh_token e long-lived.
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# Seq (logging)
# -----------------------------------------------------------------------------
# Endpoint do Seq (CLEF). Se vazio, o handler nao e instalado e os logs ficam
# apenas no stdout/journalctl.
SEQ_URL=
SEQ_API_KEY=

# -----------------------------------------------------------------------------
# Aplicacao
# -----------------------------------------------------------------------------
# Interface de rede onde o servidor escuta.
# Em producao: 0.0.0.0. Em dev: 127.0.0.1.
APP_HOST=127.0.0.1
# Porta HTTP. Padrao: 8000.
APP_PORT=8000
# Ambiente de execucao. Aceita: development | production.
APP_ENV=development

# -----------------------------------------------------------------------------
# API Auth
# -----------------------------------------------------------------------------
# Chave compartilhada para o header X-API-Key. Clientes externos devem
# enviar `X-API-Key: <valor>` em todas as chamadas a /sync/*, /fulfillment/*,
# /products, /orders. IPs em API_KEY_IP_ALLOWLIST passam sem header.
# Em production a app NAO sobe se este campo estiver vazio ou < 32 chars.
# Gerar valor forte: python -c 'import secrets; print(secrets.token_urlsafe(32))'
API_KEY=

# Lista de IPs (separados por virgula) que dispensam o X-API-Key. Default
# cobre loopback + IP publico da VPS (scripts internos chamando via hostname
# publico saem com src=212.85.1.135). Defina como string vazia para forcar
# header em todos os requests.
API_KEY_IP_ALLOWLIST=127.0.0.1,::1,212.85.1.135

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Nivel minimo de log. Aceita: DEBUG | INFO | WARNING | ERROR | CRITICAL.
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Schedules (formato cron padrao UNIX: minuto hora dia mes dia_semana)
# -----------------------------------------------------------------------------
# Sync diaria de produtos (02:00 UTC todo dia)
SYNC_PRODUCTS_CRON=0 2 * * *
# Sync incremental de pedidos (a cada 30 min)
SYNC_ORDERS_CRON=*/30 * * * *
# Reconciliacao diaria de pedidos (03:00 UTC, re-sync das orders atualizadas
# ontem para pegar cancelamentos/mudancas de status que o sync incremental
# pula via _filter_new_order_ids).
SYNC_ORDERS_RECONCILIATION_CRON=0 3 * * *
# Sync completa de estoque (03:00 UTC todo dia). Quando ML_CLIENT_ID
# esta setado, cada per-product stock pull tambem busca o Full ML
# direto da API do Mercado Livre e sobrescreve o deposito 'Full Mercado
# Livre' do Tiny (que e unreliable).
SYNC_STOCK_CRON=0 3 * * *
# Refresh dos sale buckets (04:00 UTC todo dia)
SYNC_BUCKETS_CRON=0 4 * * *
# Rotacao proativa do token (a cada 2 horas)
TOKEN_ROTATION_CRON=0 */2 * * *
# Watchdog de sync_logs presos em 'running' (a cada 5 min)
SYNC_LOG_WATCHDOG_CRON=*/5 * * * *
# Janela maxima de duracao para um sync_log antes do watchdog forcar 'failed'.
SYNC_LOG_RUNNING_MAX_MINUTES=90
# TTL do lock dedup em /sync/* (5 min)
SYNC_TRIGGER_LOCK_SECONDS=300

# GAS Web App unificado de Controle 4.0 (routing por ?action=).
#   ?action=manual_status         -> SKU color tags (GERAL B+C)
#   ?action=costs_all             -> bulk dump MERCADO LIVRE
#   ?action=cost&mlbid=MLB...     -> single-MLB (legado)
# Vazio desabilita manual_status_sync e ml_promo_recompute jobs.
GAS_BASE_URL=
GAS_TOKEN=
GAS_HTTP_TIMEOUT_SECONDS=60.0
# Cron diario de manual_status (04:30 UTC, depois de products e stock).
SYNC_MANUAL_STATUS_CRON=30 4 * * *
# Cron diario de recompute de ml_promo_caps (05:00 UTC, depois do manual_status).
SYNC_ML_PROMO_RECOMPUTE_CRON=0 5 * * *
