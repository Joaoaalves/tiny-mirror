# =============================================================================
# tiny-mirror — Variaveis de Ambiente
# =============================================================================
# Copie este arquivo para `.env` e preencha os valores reais.
# O `.env` real NUNCA deve ser commitado (ver .gitignore).

# -----------------------------------------------------------------------------
# Banco de dados
# -----------------------------------------------------------------------------
# URL de conexao assincrona com PostgreSQL.
# Formato obrigatorio: postgresql+asyncpg://usuario:senha@host:porta/nome_do_banco
# O prefixo `postgresql+asyncpg://` e obrigatorio para SQLAlchemy usar o driver async.
DATABASE_URL=postgresql+asyncpg://tiny_mirror:senha_dev_local@localhost:5432/tiny_mirror_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# URL de conexao com Redis. Formato: redis://host:porta/numero_do_banco
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
# URL de conexao com RabbitMQ. Formato: amqp://usuario:senha@host:porta/vhost
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# -----------------------------------------------------------------------------
# Tiny ERP OAuth2
# -----------------------------------------------------------------------------
# Credenciais obtidas no painel de integracoes do Tiny:
# https://erp.tiny.com.br/integracoes
TINY_CLIENT_ID=seu_client_id_aqui
TINY_CLIENT_SECRET=seu_client_secret_aqui
# URI de redirect cadastrada no Tiny. Apenas referencia — o fluxo OAuth completo
# nao e implementado neste servico.
TINY_REDIRECT_URI=https://meu-dominio.internal/oauth/callback

# -----------------------------------------------------------------------------
# Aplicacao
# -----------------------------------------------------------------------------
# Interface de rede onde o servidor escuta.
# Em producao: 0.0.0.0. Em dev: 127.0.0.1.
APP_HOST=127.0.0.1
# Porta HTTP. Padrao: 8000.
APP_PORT=8000
# Ambiente de execucao. Aceita: development | production.
APP_ENV=development

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Nivel minimo de log. Aceita: DEBUG | INFO | WARNING | ERROR | CRITICAL.
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Schedules (formato cron padrao UNIX: minuto hora dia mes dia_semana)
# -----------------------------------------------------------------------------
# Sync diaria de produtos (02:00 UTC todo dia)
SYNC_PRODUCTS_CRON=0 2 * * *
# Sync incremental de pedidos (inicio de cada hora)
SYNC_ORDERS_CRON=0 * * * *
# Sync completa de estoque (03:00 UTC todo dia)
SYNC_STOCK_CRON=0 3 * * *
# Refresh dos sale buckets (04:00 UTC todo dia)
SYNC_BUCKETS_CRON=0 4 * * *
# Rotacao proativa do token OAuth (a cada 2 horas)
TOKEN_ROTATION_CRON=0 */2 * * *
